{
  "pluginAlias": "JlrSmartcar",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name":         { "title": "Name", "type": "string", "default": "JLR InControl" },
      "clientId":     { "title": "Smartcar Client ID",     "type": "string", "required": true },
      "clientSecret": { "title": "Smartcar Client Secret", "type": "string", "required": true },
      "smartcarMode": {
        "title": "Smartcar Mode",
        "type": "string",
        "enum": ["test", "live"],
        "default": "test",
        "description": "'test' = Smartcar Simulator (kein echtes Auto n\u00f6tig). 'live' = echtes Fahrzeug. Muss mit dem Dashboard-Modus \u00fcbereinstimmen!"
      },
      "hostIp": {
        "title": "Homebridge Host IP",
        "type": "string",
        "description": "IP des Raspberry Pi (z.B. 192.168.1.42). N\u00f6tig damit der Auth-Link im Log korrekt ist.",
        "placeholder": "192.168.1.42"
      },
      "redirectUri":      { "title": "OAuth Redirect URI (optional)", "type": "string", "description": "Leer lassen – wird automatisch aus hostIp gebaut." },
      "notifyWebhookUrl": { "title": "Re-auth Webhook URL (optional)", "type": "string" },
      "pollInterval":     { "title": "Poll-Intervall (Sekunden)", "type": "integer", "default": 300, "minimum": 60 }
    },
    "required": ["clientId", "clientSecret"]
  },
  "layout": [
    { "key": "name" },
    { "type": "fieldset", "title": "Smartcar Credentials", "items": ["clientId", "clientSecret", "smartcarMode"] },
    { "type": "fieldset", "title": "Netzwerk", "items": ["hostIp", "redirectUri"] },
    { "type": "fieldset", "title": "Erweitert", "expandable": true, "expanded": false, "items": ["pollInterval", "notifyWebhookUrl"] }
  ]
}
